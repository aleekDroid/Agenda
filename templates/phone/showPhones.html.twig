{% extends 'base.html.twig' %}

{% block title %}Todos los teléfonos.
{% endblock %}

{% block body %}

{% block navbar %}
<div style="margin-top: 40px; margin-left: 40px;">
		<a class="btn btn-default" href="{{path('index')}}" role="button">{{ 'back_to_home'|trans({}, 'Agenda') }}</a>
	</div>
{% endblock %}
    	<div class="container" style="margin-top: 20px; align-items: center; justify-content: center; display: flex;">
		<div class="card" style="width: 75%;">
			<h1 class="card-header text-center mb-4">
				{{ 'all_phones'|trans({}, 'Agenda') }}
			</h1>
			<br>
			<div class="card-body; text-align: left; mt-4;">

				<table class="table table-hover">
					<thead class="text-white" style="background-color: #f2d349; border-radius: 5px;">
						<tr>
							<th scope="col">{{'phone_number'|trans({}, 'Agenda') }}</th>
							<th scope="col">{{'phone_type'|trans({}, 'Agenda') }}</th>
							<th scope="col">{{'actions'|trans({}, 'Agenda') }}</th>
						</tr>
					</thead>
					<tbody>
						{% for phone in phones %}
							<tr style="cursor: pointer; border-radius: 7px; transition: background-color 0.3s;" onmouseover="this.style.backgroundColor='#faecac';" onmouseout="this.style.backgroundColor='';">
								<td>{{ phone.number }}</td>
								<td>{{ phone.type }}</td>
								<td class="d-grid gap-5 d-md-block text-center">
									<a href="{{ path('phone_edit', {'id': phone.id}) }}" class="btn btn-primary">{{'edit'|trans({}, 'Agenda') }}</a>
									<a href="{{ path('phone_delete', {'id': phone.id}) }}" class="btn btn-danger">{{'delete'|trans({}, 'Agenda') }}</a>
							</tr>
						{% endfor %}
					</tbody>
				</table>

			</div>
		</div>
	{% endblock %}

