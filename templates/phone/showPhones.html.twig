{% extends 'base.html.twig' %}

{% block title %}Todos los teléfonos.
{% endblock %}

{% block body %}

{% block navbar %}
	<li>
		<a class="btn btn-default" href="{{path('index')}}" role="button">Back to home</a>
	</li>
{% endblock %}
    	<div class="container" style="margin-top: 20px; align-items: center; justify-content: center; display: flex;">
		<div class="card" style="width: 75%;">
			<h1 class="card-header text-center mb-4">
				All phones
			</h1>
			<br>
			<div class="card-body; text-align: left; mt-4;">

				<table class="table table-hover">
					<thead>
						<tr>
							<th scope="col">Number</th>
							<th scope="col">Type</th>
							<th scope="col">Actions</th>
						</tr>
					</thead>
					<tbody>
						{% for phone in phones %}
							<tr>
								<td>{{ phone.number }}</td>
								<td>{{ phone.type }}</td>
								<td class="d-grid gap-5 d-md-block text-center">
									<a href="{{ path('phone_edit', {'id': phone.id}) }}" class="btn btn-primary">Edit</a>
									<a href="{{ path('phone_delete', {'id': phone.id}) }}" class="btn btn-danger">Delete</a>
							</tr>
						{% endfor %}
					</tbody>
				</table>

			</div>
		</div>
	{% endblock %}

