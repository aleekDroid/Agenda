{% extends 'base.html.twig' %}

{% block title %}Hello ContactController!
{% endblock %}

{% block body %}

	{% block navbar %}
    <div class="d-grid gap-6 d-md-block text-left" style="margin-top: 40px; margin-left: 40px;">
			<a class="btn btn-default" href="{{path('index')}}" role="button">{{ 'back_to_home'|trans({}, 'Agenda') }}</a>
        </div>
	{% endblock %}
	<div class="container" style="margin-top: 20px; align-items: center; justify-content: center; display: flex;">
		<div class="card" style="width: 75%;">
			<h1 class="card-header ">
				{{ 'new_contact'|trans({}, 'Agenda') }}
			</h1>

			<div class="card">
				<div class="card-body; text-align: left;">
					{{ form_start(form) }}
                        {{ form_row(form.name) }}
                        {{ form_row(form.lastName) }}
                        {{ form_row(form.mail) }}
                        <ul class="phones" data-index="{{ form.phones|length > 0 ? form.phones|last.vars.name + 1 : 0 }}" data-prototype="{{ form_widget(form.phones.vars.prototype)|e('html_attr') }}">
                            {% for PhonesType in form.phones %}
                                <li>{{ form_row(PhonesType) }}</li>
                            {% endfor %}
                        </ul>

                        <button id="add-phone-btn" type="button" class="btn btn-info" data-collection-holder-class="phones">
                            {{'add_phone'|trans({}, 'Agenda') }}
                        </button>

                        <div id="save-button" style="margin-top: 20px;">
                        {{ form_row(form.save) }}
                        </div>

                        <script>
                            document.getElementById('add-phone-btn').addEventListener("click", addFormToCollection);

                            function addFormToCollection(e) {
                                const collectionHolder = document.querySelector('.' + e.currentTarget.dataset.collectionHolderClass);

                                const item = document.createElement('li');

                                item.innerHTML = collectionHolder.
                                    dataset.
                                    prototype.
                                    replace(
                                        /__name__/g, 
                                        collectionHolder.dataset.index
                                    );

                                collectionHolder.appendChild(item);

                                collectionHolder.dataset.index ++;
                                addTagFormDeleteLink(item);
                            };

                            function addTagFormDeleteLink(item) {
                                const removeFormButton = document.createElement('button');
                                removeFormButton.innerText = 'Delete this phone number';
                                removeFormButton.classList.add('btn', 'btn-danger');
                                removeFormButton.style.marginTop = '10px';

                                item.append(removeFormButton);

                                removeFormButton.addEventListener('click', (e) => {
                                e.preventDefault();
                                // remove the li for the tag form
                                item.remove();
                                });
                            }

                            $('#save-button').on('click', function() {
                                Swal.fire({
                                    title: '{{ "contact_created" |trans({}, "Agenda") }}',
                                    icon: 'success',
                                    confirmButtonText: '{{ "ok" |trans({}, "Agenda") }}'
                                });
                            });
                        </script>

					{{ form_end(form) }}

				</div>
			</div>
		</div>
	{% endblock %}
