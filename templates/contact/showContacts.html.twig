{% extends 'base.html.twig' %}

{% block title %}Todos los contactos.
{% endblock %}

{% block body %}
{% block navbar %}
	<li>
		<a class="btn btn-default" href="{{path('index')}}" role="button">Back to home</a>
	</li>
{% endblock %}
	<div class="container" style="margin-top: 20px; align-items: center; justify-content: center; display: flex;">
		<div class="card" style="width: 75%;">
			<h1 class="card-header text-center mb-4">
				All contacts
			</h1>
			<br>
			<div class="card-body; text-align: left; mt-4;">

				<table class="table table-hover">
					<thead class="text-white" style="background-color: #f2d349;">
						<tr>
							<th scope="col">Name</th>
							<th scope="col">Last Name</th>
							<th scope="col">Mail</th>
							<th scope="col">Phones</th>
							<th scope="col">Actions</th>
						</tr>
					</thead>
					<tbody>
						{% for contact in contacts %}
							<tr>
								<td>{{ contact.name }}</td>
								<td>{{ contact.lastName }}</td>
								<td>{{ contact.mail }}</td>
								<td>
									{% for phone in contact.phones %}
										{{ phone.number }} <br>
									{% endfor %}
								</td>
								<td class="d-grid gap-5 d-md-block text-center">
									<a href="{{ path('contact_edit', {'id': contact.id}) }}" class="btn btn-success">Edit</a>
									<a href="{{ path('contact_delete', {'id': contact.id}) }}" class="btn btn-danger">Delete</a>
								</td>	
							</tr>
						{% endfor %}
					</tbody>
				</table>

			</div>
		</div>
	{% endblock %}
